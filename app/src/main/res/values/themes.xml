<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MyFitnessApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="materialCalendarTheme">@style/ThemeOverlay.MyFitnessApp.MaterialCalendar</item>
        <item name="materialTimePickerTheme">@style/ThemeOverlay.MyFitnessApp.MaterialTimePicker</item>
    </style>

    <style name="Theme.MyFitnessApp" parent="Base.Theme.MyFitnessApp" />

    <style name="ThemeOverlay.MyFitnessApp.AlertDialog" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <item name="backgroundTint">@color/card_background</item>
        <item name="colorPrimary">@color/health_action_text</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.MyFitnessApp.AlertDialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.MyFitnessApp.AlertDialog.Body</item>
    </style>

    <style name="TextAppearance.MyFitnessApp.AlertDialog.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.MyFitnessApp.AlertDialog.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="ThemeOverlay.MyFitnessApp.MaterialCalendar" parent="ThemeOverlay.Material3.MaterialCalendar">
        <item name="colorPrimary">@color/health_action_text</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/card_background</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
    </style>

    <style name="ThemeOverlay.MyFitnessApp.MaterialTimePicker" parent="ThemeOverlay.Material3.MaterialTimePicker">
        <item name="colorPrimary">@color/health_action_text</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/card_background</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
    </style>
</resources>
