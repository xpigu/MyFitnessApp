<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinator_training"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_100"
    android:fitsSystemWindows="true"
    tools:context=".TrainingActivity">

    <!-- ============================================================
         可滚动内容区域
         ============================================================ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll_training"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="?attr/actionBarSize"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp">

            <!-- ============================================================
                 1. 头部区域 (Header)
                 ============================================================ -->
            <LinearLayout
                android:id="@+id/training_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="8dp"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_training_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/training_title"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_training_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="2026年6月4日 周四"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- 日历图标 -->
                <ImageView
                    android:id="@+id/iv_calendar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/category_chip_unselected"
                    android:contentDescription="日历"
                    android:padding="10dp"
                    android:src="@drawable/ic_notification" />
            </LinearLayout>

            <!-- ============================================================
                 2. 快速开始 (Quick Start)
                 ============================================================ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_quick_start"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:contentPadding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="@string/training_quick_start"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- 2x3 网格 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- 第一行 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- 跑步 -->
                            <LinearLayout
                                android:id="@+id/workout_running"
                                android:layout_width="0dp"
                                android:layout_height="100dp"
                                android:layout_marginEnd="8dp"
                                android:layout_marginBottom="8dp"
                                android:layout_weight="1"
                                android:background="@drawable/workout_card_bg"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="@drawable/start_button_bg"
                                    android:contentDescription="@string/workout_running"
                                    android:padding="6dp"
                                    android:src="@drawable/ic_running" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="@string/workout_running"
                                    android:textColor="@color/text_primary"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="30 min"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <!-- 骑行 -->
                            <LinearLayout
                                android:id="@+id/workout_cycling"
                                android:layout_width="0dp"
                                android:layout_height="100dp"
                                android:layout_marginEnd="8dp"
                                android:layout_marginBottom="8dp"
                                android:layout_weight="1"
                                android:background="@drawable/workout_card_bg"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="@drawable/start_button_bg"
                                    android:backgroundTint="@color/emerald_secondary"
                                    android:contentDescription="@string/workout_cycling"
                                    android:padding="6dp"
                                    android:src="@drawable/ic_cycling" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="@string/workout_cycling"
                                    android:textColor="@color/text_primary"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="45 min"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <!-- 瑜伽 -->
                            <LinearLayout
                                android:id="@+id/workout_yoga"
                                android:layout_width="0dp"
                                android:layout_height="100dp"
                                android:layout_marginBottom="8dp"
                                android:layout_weight="1"
                                android:background="@drawable/workout_card_bg"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="@drawable/start_button_bg"
                                    android:backgroundTint="@color/gold_accent"
                                    android:contentDescription="@string/workout_yoga"
                                    android:padding="6dp"
                                    android:src="@drawable/ic_yoga" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="@string/workout_yoga"
                                    android:textColor="@color/text_primary"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="20 min"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- 第二行 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- 力量 -->
                            <LinearLayout
                                android:id="@+id/workout_strength"
                                android:layout_width="0dp"
                                android:layout_height="100dp"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:background="@drawable/workout_card_bg"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="@drawable/start_button_bg"
                                    android:backgroundTint="#E74C3C"
                                    android:contentDescription="@string/workout_strength"
                                    android:padding="6dp"
                                    android:src="@drawable/ic_strength_white" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="@string/workout_strength"
                                    android:textColor="@color/text_primary"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="40 min"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <!-- 游泳 -->
                            <LinearLayout
                                android:id="@+id/workout_swimming"
                                android:layout_width="0dp"
                                android:layout_height="100dp"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:background="@drawable/workout_card_bg"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="@drawable/start_button_bg"
                                    android:backgroundTint="#3498DB"
                                    android:contentDescription="@string/workout_swimming"
                                    android:padding="6dp"
                                    android:src="@drawable/ic_swimming" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="@string/workout_swimming"
                                    android:textColor="@color/text_primary"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="60 min"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <!-- 跳绳 -->
                            <LinearLayout
                                android:id="@+id/workout_jump_rope"
                                android:layout_width="0dp"
                                android:layout_height="100dp"
                                android:layout_weight="1"
                                android:background="@drawable/workout_card_bg"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="@drawable/start_button_bg"
                                    android:backgroundTint="#E67E22"
                                    android:contentDescription="@string/workout_jump_rope"
                                    android:padding="6dp"
                                    android:src="@drawable/ic_jump_rope" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="@string/workout_jump_rope"
                                    android:textColor="@color/text_primary"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="15 min"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ============================================================
                 3. 运动课程 (Workout Courses)
                 ============================================================ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_workout_courses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:contentPadding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/workout_courses"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- 运动类型横栏 Tab -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/ll_course_tabs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tab_course_running"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/category_chip_selected"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingStart="16dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="8dp"
                                android:text="@string/workout_running"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tab_course_cycling"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/category_chip_unselected"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingStart="16dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="8dp"
                                android:text="@string/workout_cycling"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tab_course_yoga"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/category_chip_unselected"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingStart="16dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="8dp"
                                android:text="@string/workout_yoga"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tab_course_strength"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/category_chip_unselected"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingStart="16dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="8dp"
                                android:text="@string/workout_strength"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tab_course_swimming"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/category_chip_unselected"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingStart="16dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="8dp"
                                android:text="@string/workout_swimming"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tab_course_jump_rope"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/category_chip_unselected"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingStart="16dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="8dp"
                                android:text="@string/workout_jump_rope"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </HorizontalScrollView>

                    <!-- 课程列表容器 -->
                    <LinearLayout
                        android:id="@+id/ll_course_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <!-- 课程卡片 -->
                        <LinearLayout
                            android:id="@+id/course_item_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:background="@drawable/workout_history_bg"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="12dp">

                            <ImageView
                                android:id="@+id/iv_course_icon"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/start_button_bg"
                                android:contentDescription="课程"
                                android:padding="8dp"
                                android:src="@drawable/ic_running" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_course_1_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="5公里入门跑"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_course_1_info"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="初学者 · 30分钟 · 约300 kcal"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/btn_course_start"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/add_food_btn_bg"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingStart="12dp"
                                android:paddingTop="6dp"
                                android:paddingEnd="12dp"
                                android:paddingBottom="6dp"
                                android:text="开始"
                                android:textColor="@color/indigo_primary"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- 课程卡片 -->
                        <LinearLayout
                            android:id="@+id/course_item_2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:background="@drawable/workout_history_bg"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="12dp">

                            <ImageView
                                android:id="@+id/iv_course_icon"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/start_button_bg"
                                android:contentDescription="课程"
                                android:padding="8dp"
                                android:src="@drawable/ic_running" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_course_2_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="燃脂间歇跑"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_course_2_info"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="中级 · 45分钟 · 约450 kcal"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/btn_course_start"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/add_food_btn_bg"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingStart="12dp"
                                android:paddingTop="6dp"
                                android:paddingEnd="12dp"
                                android:paddingBottom="6dp"
                                android:text="开始"
                                android:textColor="@color/indigo_primary"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- 课程卡片 -->
                        <LinearLayout
                            android:id="@+id/course_item_3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/workout_history_bg"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="12dp">

                            <ImageView
                                android:id="@+id/iv_course_icon"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/start_button_bg"
                                android:contentDescription="课程"
                                android:padding="8dp"
                                android:src="@drawable/ic_running" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_course_3_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="跑后拉伸放松"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_course_3_info"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="所有级别 · 15分钟 · 约80 kcal"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/btn_course_start"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/add_food_btn_bg"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingStart="12dp"
                                android:paddingTop="6dp"
                                android:paddingEnd="12dp"
                                android:paddingBottom="6dp"
                                android:text="开始"
                                android:textColor="@color/indigo_primary"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ============================================================
         底部导航 (Bottom Navigation)
         ============================================================ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:minHeight="80dp"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/indigo_primary"
        app:itemTextColor="@color/indigo_primary"
