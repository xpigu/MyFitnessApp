<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/iv_badge_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_achievement" />

        <TextView
            android:id="@+id/tv_badge_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="初出茅庐" />

        <TextView
            android:id="@+id/tv_badge_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            tools:text="完成第一次运动" />

        <TextView
            android:id="@+id/tv_unlock_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/emerald_secondary"
            android:textSize="10sp"
            android:visibility="gone"
            tools:text="已于 2026-06-06 解锁"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tv_badge_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:visibility="gone"
            tools:text="当前进度 2/7"
            tools:visibility="visible" />

        <ProgressBar
            android:id="@+id/progress_badge"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="6dp"
            android:max="100"
            android:progress="35"
            android:progressTint="@color/achievement_progress_tint"
            android:visibility="gone"
            tools:progress="35"
            tools:visibility="visible" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
