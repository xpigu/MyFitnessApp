<?xml version="1.0" encoding="utf-8"?>
<!--
    户外运动追踪界面（跑步/骑行）
    结构：地图(固定顶部) + 可滚动数据区 + 控制栏(固定底部)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_tracking"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fitsSystemWindows="true"
    tools:context=".WorkoutTrackingActivity">

    <!-- 地图高度 GuideLine，运行时动态调整比例 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_map"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.40" />

    <!-- ============================================================
         地图占位区（固定顶部）
         ============================================================ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/map_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="visible"
        app:cardBackgroundColor="#2A2A3E"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/guideline_map"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <fragment
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- 渐变遮罩，让地图和下方数据区过渡更自然 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_gravity="bottom"
            android:background="@drawable/map_gradient_overlay" />
            
        <TextView
            android:id="@+id/tv_max_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/tab_bg_unselected"
            android:paddingStart="12dp"
            android:paddingTop="4dp"
            android:paddingEnd="12dp"
            android:paddingBottom="4dp"
            android:text="最高 0.0 km/h"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:visibility="gone"
            tools:visibility="visible" />
    </androidx.cardview.widget.CardView>

    <!-- 折叠/展开地图按钮 -->
    <TextView
        android:id="@+id/btn_toggle_map"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="-16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/circle_bg"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="⌃"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/guideline_map"
        tools:visibility="visible" />

    <!-- ============================================================
         可滚动数据区
         ============================================================ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_data"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/control_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/guideline_map">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <!-- 运动类型图标 + 名称 -->
            <ImageView
                android:id="@+id/iv_tracking_sport_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/start_button_bg"
                android:contentDescription="运动类型"
                android:padding="8dp"
                tools:src="@drawable/ic_running" />

            <TextView
                android:id="@+id/tv_tracking_sport_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="户外跑步" />

            <!-- 计时器 -->
            <TextView
                android:id="@+id/tv_tracking_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="monospace"
                android:text="00:00:00"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                tools:text="00:12:35" />

            <!-- 状态标签 -->
            <TextView
                android:id="@+id/tv_tracking_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:background="@drawable/tab_bg_unselected"
                android:paddingStart="10dp"
                android:paddingTop="2dp"
                android:paddingEnd="10dp"
                android:paddingBottom="2dp"
                android:text="运动中"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tv_course_phase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="热身步行"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="热身步行"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tv_course_phase_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp"
                android:text="目标：舒适配速 · 剩余 04:30"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="目标：舒适配速 · 剩余 04:30"
                tools:visibility="visible" />

            <!-- 跑步专属：Lap + 节拍器 -->
            <LinearLayout
                android:id="@+id/ll_run_extras"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/btn_lap"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/tab_bg_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="分段"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/chip_metronome"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:background="@drawable/tab_bg_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="节拍器"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- 一级数据：配速/速度 -->
            <LinearLayout
                android:id="@+id/primary_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_primary_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="6&#39;00&#39;&#39;"
                    android:textColor="#FF6B35"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    tools:text="6'00&quot;" />

                <TextView
                    android:id="@+id/tv_primary_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="配速 /km"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <!-- 距离 + 用时 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_sub_distance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.00"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="3.25" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="公里"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="28dp"
                        android:layout_marginStart="14dp"
                        android:layout_marginEnd="14dp"
                        android:background="#33FFFFFF" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_sub_timer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="00:00:00"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="00:12:35" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="用时"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 二级数据卡（根据数量自动均分） -->
            <LinearLayout
                android:id="@+id/ll_secondary_cards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                    <!-- 卡片槽位 0 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_secondary_0"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/card_background"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:minHeight="82dp"
                            android:orientation="vertical"
                            android:paddingTop="8dp"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:paddingBottom="8dp">

                            <TextView
                                android:id="@+id/tv_secondary_label_0"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/text_secondary"
                                android:textSize="9sp" />

                            <TextView
                                android:id="@+id/tv_secondary_0"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="0"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_secondary_unit_0"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/text_secondary"
                                android:textSize="8sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- 卡片槽位 1 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_secondary_1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/card_background"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:minHeight="82dp"
                            android:orientation="vertical"
                            android:paddingTop="8dp"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:paddingBottom="8dp">

                            <TextView
                                android:id="@+id/tv_secondary_label_1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/text_secondary"
                                android:textSize="9sp" />

                            <TextView
                                android:id="@+id/tv_secondary_1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="0"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_secondary_unit_1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/text_secondary"
                                android:textSize="8sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- 卡片槽位 2 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_secondary_2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/card_background"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:minHeight="82dp"
                            android:orientation="vertical"
                            android:paddingTop="8dp"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:paddingBottom="8dp">

                            <TextView
                                android:id="@+id/tv_secondary_label_2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/text_secondary"
                                android:textSize="9sp" />

                            <TextView
                                android:id="@+id/tv_secondary_2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="0"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_secondary_unit_2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/text_secondary"
                                android:textSize="8sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- 卡片槽位 3 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_secondary_3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:visibility="gone"
                        app:cardBackgroundColor="@color/card_background"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:minHeight="82dp"
                            android:orientation="vertical"
                            android:paddingTop="8dp"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:paddingBottom="8dp">

                            <TextView
                                android:id="@+id/tv_secondary_label_3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/text_secondary"
                                android:textSize="9sp" />

                            <TextView
                                android:id="@+id/tv_secondary_3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="0"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_secondary_unit_3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/text_secondary"
                                android:textSize="8sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ============================================================
         底部控制栏（固定底部）
         ============================================================ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/control_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#1A1A2E"
        android:paddingStart="20dp"
        android:paddingTop="12dp"
        android:paddingEnd="20dp"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- 停止 -->
        <TextView
            android:id="@+id/btn_stop"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/circle_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="■"
            android:textColor="#E74C3C"
            android:textSize="20sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 暂停/继续 -->
        <TextView
            android:id="@+id/btn_pause_resume"
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:background="@drawable/start_button_bg"
            android:clickable="true"
            android:focusable="true"
            android:drawableTop="@drawable/ic_pause"
            android:gravity="center"
            android:paddingTop="16dp"
            android:text="暂停"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 右侧按钮组 -->
        <LinearLayout
            android:id="@+id/right_action_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- 锁屏（跑步） -->
            <TextView
                android:id="@+id/btn_lock_screen"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/circle_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="🔒"
                android:textSize="14sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- 语音播报 -->
            <TextView
                android:id="@+id/btn_voice"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="🔊"
                android:textSize="14sp" />

            <!-- 自动暂停（骑行） -->
            <TextView
                android:id="@+id/btn_auto_pause"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_bg_unselected"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="自动暂停: 开"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
