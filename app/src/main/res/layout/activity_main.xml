<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinator_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_100"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <!-- ============================================================
         可滚动内容区域
         ============================================================ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="?attr/actionBarSize"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp">

            <!-- ============================================================
                 1. 头部区域 (Header)
                 ============================================================ -->
            <LinearLayout
                android:id="@+id/header_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="8dp"
                android:paddingBottom="16dp">

                <!-- 左侧：问候语 + 用户名 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/greeting_morning"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        tools:text="早上好" />

                    <TextView
                        android:id="@+id/tv_user_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="健身达人"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="健身达人" />
                </LinearLayout>

                <!-- 右侧：通知图标 + 用户头像 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- 通知图标按钮 -->
                    <ImageButton
                        android:id="@+id/ib_notification"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="通知"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_notification" />

                    <!-- 圆形用户头像 -->
                    <ImageView
                        android:id="@+id/iv_avatar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/avatar_placeholder"
                        android:contentDescription="用户头像"
                        android:scaleType="centerCrop" />
                </LinearLayout>
            </LinearLayout>

            <!-- ============================================================
                 2. 今日进度 (Today's Progress)
                 ============================================================ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_today_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:contentPadding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 标题 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="@string/today_progress"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- 三个圆形进度条 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <!-- 步数 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="80dp"
                                android:layout_height="80dp">

                                <ImageView
                                    android:id="@+id/iv_steps_progress"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/circle_progress_indigo" />

                                <TextView
                                    android:id="@+id/tv_steps_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="8,523"
                                    android:textColor="@color/indigo_primary"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    tools:text="8,523" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tv_steps_unit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/steps_unit"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tv_steps_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/steps"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- 卡路里 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="80dp"
                                android:layout_height="80dp">

                                <ImageView
                                    android:id="@+id/iv_calories_progress"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/circle_progress_emerald" />

                                <TextView
                                    android:id="@+id/tv_calories_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="486"
                                    android:textColor="@color/emerald_dark"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    tools:text="486" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tv_calories_unit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/calories_unit"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tv_calories_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/calories"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- 睡眠 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="80dp"
                                android:layout_height="80dp">

                                <ImageView
                                    android:id="@+id/iv_sleep_progress"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/circle_progress_gold" />

                                <TextView
                                    android:id="@+id/tv_sleep_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="7.5"
                                    android:textColor="@color/gold_dark"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    tools:text="7.5" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tv_sleep_unit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/sleep_unit"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tv_sleep_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/sleep"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ============================================================
                 3. 心率卡片 (Heart Rate Card)
                 ============================================================ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_heart_rate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:contentPadding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 心率标题行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="心率"
                            android:src="@drawable/ic_heart_rate" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="@string/heart_rate"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <!-- 最高/最低标注 -->
                        <TextView
                            android:id="@+id/tv_heart_rate_max"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/max_rate"
                            android:textColor="#E74C3C"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_heart_rate_min"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="@string/min_rate"
                            android:textColor="@color/emerald_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- 实时心率数字 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_heart_rate_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="72"
                            android:textColor="#E74C3C"
                            android:textSize="48sp"
                            android:textStyle="bold"
                            tools:text="72" />

                        <TextView
                            android:id="@+id/tv_heart_rate_unit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/bpm"
                            android:textColor="@color/text_secondary"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- 心率面积图占位 -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginTop="12dp">

                        <ImageView
                            android:id="@+id/iv_heart_rate_chart"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/heart_rate_chart_placeholder"
                            android:contentDescription="心率趋势图"
                            android:scaleType="fitXY" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="心率趋势图"
                            android:textColor="@color/gray_400"
                            android:textSize="12sp" />
                    </FrameLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ============================================================
                 4. 活跃挑战 (Active Challenges)
                 ============================================================ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_active_challenges"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:contentPadding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 标题 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/active_challenges"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- 横向滚动挑战卡片 -->
                    <HorizontalScrollView
                        android:id="@+id/hsv_challenges"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/ll_challenge_container"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- 挑战卡片 1：周末战士 -->
                            <LinearLayout
                                android:id="@+id/challenge_card_1"
                                android:layout_width="150dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/challenge_card_bg"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <TextView
                                    android:id="@+id/tv_challenge_1_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/challenge_weekend_warrior"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <ProgressBar
                                    android:id="@+id/pb_challenge_1"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="6dp"
                                    android:layout_marginTop="8dp"
                                    android:max="100"
                                    android:progress="60"
                                    android:progressDrawable="@drawable/progress_bar_fill"
                                    tools:progress="60" />

                                <TextView
                                    android:id="@+id/tv_challenge_1_progress"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="60%"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <!-- 挑战卡片 2：燃脂达人 -->
                            <LinearLayout
                                android:id="@+id/challenge_card_2"
                                android:layout_width="150dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/challenge_card_bg"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <TextView
                                    android:id="@+id/tv_challenge_2_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/challenge_fat_burner"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <ProgressBar
                                    android:id="@+id/pb_challenge_2"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="6dp"
                                    android:layout_marginTop="8dp"
                                    android:max="100"
                                    android:progress="35"
                                    android:progressDrawable="@drawable/progress_bar_fill"
                                    tools:progress="35" />

                                <TextView
                                    android:id="@+id/tv_challenge_2_progress"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="35%"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <!-- 挑战卡片 3：步行挑战 -->
                            <LinearLayout
                                android:id="@+id/challenge_card_3"
                                android:layout_width="150dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/challenge_card_bg"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <TextView
                                    android:id="@+id/tv_challenge_3_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/challenge_walking"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <ProgressBar
                                    android:id="@+id/pb_challenge_3"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="6dp"
                                    android:layout_marginTop="8dp"
                                    android:max="100"
                                    android:progress="80"
                                    android:progressDrawable="@drawable/progress_bar_fill"
                                    tools:progress="80" />

                                <TextView
                                    android:id="@+id/tv_challenge_3_progress"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="80%"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <!-- 挑战卡片 4：早起运动 -->
                            <LinearLayout
                                android:id="@+id/challenge_card_4"
                                android:layout_width="150dp"
                                android:layout_height="wrap_content"
                                android:background="@drawable/challenge_card_bg"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <TextView
                                    android:id="@+id/tv_challenge_4_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/challenge_morning_workout"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <ProgressBar
                                    android:id="@+id/pb_challenge_4"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="6dp"
                                    android:layout_marginTop="8dp"
                                    android:max="100"
                                    android:progress="45"
                                    android:progressDrawable="@drawable/progress_bar_fill"
                                    tools:progress="45" />

                                <TextView
                                    android:id="@+id/tv_challenge_4_progress"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="45%"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>

                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ============================================================
         5. 底部导航 (Bottom Navigation)
         ============================================================ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:minHeight="80dp"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/indigo_primary"
        app:itemTextColor="@color/indigo_primary"
        app:itemRippleColor="@color/indigo_light"
        app:labelVisibilityMode="labeled"
        android:background="@color/card_background"
        app:elevation="8dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>