<?xml version="1.0" encoding="utf-8"?>
<!--
    璺崇怀璁℃暟鐣岄潰
    鍏ㄥ睆娌夋蹈寮忎綋楠岋紝涓ぎ瓒呭ぇ璁℃暟
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tracking_surface"
    android:fitsSystemWindows="true"
    tools:context=".JumpRopeActivity">

    <ImageButton
        android:id="@+id/btn_jump_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/tracking_control_circle_bg"
        android:contentDescription="杩斿洖璁粌涓婚〉"
        android:padding="10dp"
        android:scaleX="-1"
        android:src="@drawable/ic_arrow_right"
        app:tint="@color/tracking_on_primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 椤堕儴鏍囬 -->
    <LinearLayout
        android:id="@+id/header_jump_rope"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="48dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_jump_rope_icon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/start_button_bg"
            android:backgroundTint="@color/training_jump_rope_badge_fill"
            android:contentDescription="璺崇怀"
            android:padding="12dp"
            android:src="@drawable/ic_jump_rope" />

        <TextView
            android:id="@+id/tv_jump_header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="璺崇怀"
            android:textColor="@color/tracking_on_primary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_jump_course_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/tracking_chip_bg"
            android:paddingStart="12dp"
            android:paddingTop="4dp"
            android:paddingEnd="12dp"
            android:paddingBottom="4dp"
            android:text="跳绳基础入门 · 7 个回合"
            android:textColor="@color/sport_header_secondary_text"
            android:textSize="12sp"
            android:visibility="gone"
            tools:text="跳绳基础入门 · 7 个回合"
            tools:visibility="visible" />
    </LinearLayout>

    <!-- 涓ぎ瓒呭ぇ璁℃暟 -->
    <LinearLayout
        android:id="@+id/center_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/bottom_data"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_jump_rope"
        app:layout_constraintVertical_bias="0.5">

        <TextView
            android:id="@+id/tv_jump_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="0"
            android:textColor="@color/tracking_on_primary"
            android:textSize="96sp"
            android:textStyle="bold"
            tools:text="128" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="次"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- 鐘舵€佹爣绛?-->
    <TextView
        android:id="@+id/tv_jump_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/tracking_chip_bg"
        android:paddingStart="12dp"
        android:paddingTop="4dp"
        android:paddingEnd="12dp"
        android:paddingBottom="4dp"
        android:text="准备开始"
        android:textColor="@color/tracking_on_primary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/center_count" />

    <TextView
        android:id="@+id/tv_jump_round_detail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="褰撳墠鍥炲悎锛氱儹韬皬璺?路 鐩爣 90 娆?鍒嗛挓"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_jump_status"
        tools:text="褰撳墠鍥炲悎锛氱儹韬皬璺?路 鐩爣 90 娆?鍒嗛挓"
        tools:visibility="visible" />

    <!-- 搴曢儴鏁版嵁鍗＄墖 -->
    <LinearLayout
        android:id="@+id/bottom_data"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="120dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tracking_card_bg"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="鐢ㄦ椂"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_jump_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="monospace"
                    android:text="00:00"
                    android:textColor="@color/tracking_on_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tracking_card_bg"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="棰戠巼"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_jump_frequency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="0"
                    android:textColor="@color/tracking_summary_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="涓?鍒嗛挓"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tracking_card_bg"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="鐑噺"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_jump_calories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="0"
                    android:textColor="@color/tracking_summary_calories"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="kcal"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- 鎺у埗鎸夐挳 -->
    <LinearLayout
        android:id="@+id/control_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="48dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/btn_jump_start"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/tracking_primary_btn_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="开始"
            android:textColor="@color/tracking_primary_button_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_jump_stop"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="32dp"
            android:background="@drawable/tracking_control_circle_bg"
            android:clickable="true"
            android:drawableTop="@drawable/ic_stop"
            android:focusable="true"
            android:gravity="center"
            android:text="缁撴潫"
            android:textColor="@color/tracking_on_primary"
            android:textSize="11sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
