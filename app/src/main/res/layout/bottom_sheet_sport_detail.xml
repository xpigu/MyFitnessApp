<?xml version="1.0" encoding="utf-8"?>
<!--
    BottomSheetDialogFragment 底部弹窗布局
    展示单条运动记录的详细数据
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/bottom_sheet_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_bg"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- 拖拽手柄 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/tracking_divider" />

    <!-- 标题行：运动类型 + 名称 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/detail_iv_sport_type"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/start_button_bg"
            android:contentDescription="运动类型"
            android:padding="12dp"
            tools:src="@drawable/ic_running" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/detail_tv_sport_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="户外跑步" />

            <TextView
                android:id="@+id/detail_tv_sport_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                tools:text="2026年6月4日 早上 08:30" />
        </LinearLayout>
    </LinearLayout>

    <!-- ============================================================
         数据指标网格 (2x2)
         ============================================================ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <!-- 运动时长 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/detail_card_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/detail_duration"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/detail_tv_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/training_course_action_text"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="32:15" />
        </LinearLayout>

        <!-- 距离 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/detail_card_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/detail_label_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/detail_distance"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/detail_tv_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/tracking_summary_distance"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="5.20" />

            <TextView
                android:id="@+id/detail_unit_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/detail_km"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <!-- 平均速度 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/detail_card_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/detail_label_avg_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/detail_avg_speed"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/detail_tv_avg_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/tracking_summary_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="9.7" />

            <TextView
                android:id="@+id/detail_unit_avg_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/detail_kmh"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 平均配速 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/detail_card_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/detail_label_pace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/detail_pace"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/detail_tv_pace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/tracking_stop_text"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="6&apos;12&quot;" />

            <TextView
                android:id="@+id/detail_unit_pace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/detail_min_per_km"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 消耗热量 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/detail_card_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/detail_calories"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/detail_tv_calories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/tracking_summary_calories"
            android:textSize="22sp"
            android:textStyle="bold"
            tools:text="450 kcal" />
    </LinearLayout>

    <!-- 底部留白 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="24dp" />

</LinearLayout>
