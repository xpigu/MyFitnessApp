<?xml version="1.0" encoding="utf-8"?>
<!--
    运动完成摘要底部弹窗
    展示本次运动的关键数据
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/summary_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_bg"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- 拖拽手柄 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/tracking_divider" />

    <!-- 标题 -->
    <TextView
        android:id="@+id/summary_tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="运动完成！"
        android:textColor="@color/tracking_summary_title"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/summary_tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="20dp"
        android:text="本次运动数据摘要"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/settings_divider" />

    <!-- 数据行：总时长 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="总时长"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/summary_tv_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="00:32:15" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/settings_divider" />

    <!-- 数据行：总距离 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="总距离"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/summary_tv_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/tracking_summary_distance"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="5.20 公里" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/settings_divider" />

    <!-- 数据行：总热量 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="总热量"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/summary_tv_calories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/tracking_summary_calories"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="450 kcal" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/settings_divider" />

    <!-- 数据行：平均配速/速度 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="平均配速"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/summary_tv_avg_pace"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/tracking_summary_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="6&apos;12&quot;" />
    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="14dp"
        android:background="@color/settings_divider" />

    <LinearLayout
        android:id="@+id/summary_course_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/advice_card_bg"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/summary_tv_course_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="课程：城市休闲骑行"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="课程：城市休闲骑行" />

        <TextView
            android:id="@+id/summary_tv_course_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="课程进度：4/4 步，完成度 100%"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            tools:text="课程进度：4/4 步，完成度 100%" />

        <TextView
            android:id="@+id/summary_tv_course_goal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="目标达成：已完成课程计划时长与主要阶段"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            tools:text="目标达成：已完成课程计划时长与主要阶段" />
    </LinearLayout>

    <!-- 按钮组 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/summary_btn_discard"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:background="@drawable/dialog_goal_secondary_btn_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="放弃"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/summary_btn_save"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/tracking_primary_btn_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="保存记录"
            android:textColor="@color/tracking_primary_button_text"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/summary_tv_save_guard_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:visibility="gone"
        tools:text="至少达到 0.05 公里且持续 30 秒后才可保存"
        tools:visibility="visible" />

</LinearLayout>
