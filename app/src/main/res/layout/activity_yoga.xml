<?xml version="1.0" encoding="utf-8"?>
<!--
    瑜伽指导界面
    体式引导图/动画、呼吸提示、倒计时
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    tools:context=".YogaActivity">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btn_yoga_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="返回"
            android:padding="8dp"
            android:rotation="90"
            android:src="@drawable/ic_chevron_down" />

        <TextView
            android:id="@+id/tv_yoga_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="瑜伽"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_pose_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1/12"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_yoga_course_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:background="@drawable/tab_bg_unselected"
        android:paddingStart="12dp"
        android:paddingTop="4dp"
        android:paddingEnd="12dp"
        android:paddingBottom="4dp"
        android:text="晨间唤醒 · 9 个步骤"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:visibility="gone"
        tools:text="晨间唤醒 · 9 个步骤"
        tools:visibility="visible" />

    <!-- 体式图占位区 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="20dp"
        android:layout_weight="1"
        app:cardBackgroundColor="#2A2A3E"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_yoga_pose"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/start_button_bg"
                android:contentDescription="体式"
                android:padding="30dp"
                android:src="@drawable/ic_yoga" />

            <TextView
                android:id="@+id/tv_pose_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="山式"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_pose_instruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="双脚并拢，身体直立，双臂自然下垂"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 倒计时环 -->
    <FrameLayout
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp">

        <ImageView
            android:id="@+id/iv_yoga_timer_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/circle_progress_emerald" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_pose_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="30"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="秒"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- 呼吸引导 -->
    <LinearLayout
        android:id="@+id/breath_guide"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/advice_card_bg"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="呼吸"
            android:src="@drawable/ic_lightbulb" />

        <TextView
            android:id="@+id/tv_breath_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="吸气"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 控制按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_yoga_skip"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/circle_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="跳过"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btn_yoga_pause"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:background="@drawable/circle_progress_indigo"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="暂停"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_yoga_end"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/circle_bg"
            android:clickable="true"
            android:drawableTop="@drawable/ic_stop"
            android:focusable="true"
            android:gravity="center"
            android:text="结束"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
